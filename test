import cv2

def draw_box(img, box, confidence):
    x1, y1, x2, y2 = box
    c = max(0.0, min(1.0, confidence))

    # Color: green (high) → orange (low) in BGR
    low = (0, 165, 255)   # orange
    high = (0, 255, 0)    # green
    color = tuple(int(low[i] * (1 - c) + high[i] * c) for i in range(3))

    # Thickness scales with confidence
    thickness = int(1 + 3 * c)

    # Draw bounding box
    cv2.rectangle(img, (x1, y1), (x2, y2), color, thickness)

    # Rounded confidence label
    label = f"{c:.2f}"

    # Get text size
    (w, h), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_SIMPLEX, 0.5, 1)

    # Ensure label stays inside image
    y_text = max(y1 - 5, h + 5)

    # Background rectangle (filled)
    cv2.rectangle(img, (x1, y_text - h - 4), (x1 + w, y_text), color, -1)

    # Text (black for contrast)
    cv2.putText(img, label, (x1, y_text - 2),
                cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 0, 0), 1, cv2.LINE_AA)

    return img


# -------------------------
# Example usage
# -------------------------
if __name__ == "__main__":
    img = cv2.imread("image.jpg")  # replace with your image path

    # Example bounding boxes: (x1, y1, x2, y2) + confidence
    detections = [
        ((50, 40, 180, 140), 0.87),
        ((200, 80, 320, 200), 0.45),
        ((100, 200, 220, 320), 0.12),
    ]

    for box, conf in detections:
        draw_box(img, box, conf)

    cv2.imshow("Detections", img)
    cv2.waitKey(0)
    cv2.destroyAllWindows()
