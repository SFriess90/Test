from pathlib import Path
import shutil


def flatten_sequences(root: str = ".") -> None:
    base = Path(root).resolve()
    sequences_dir = base / "sequences"
    out_annotations = base / "annotations"
    out_videos = base / "videos"

    if not sequences_dir.is_dir():
        raise FileNotFoundError(f"Missing folder: {sequences_dir}")

    out_annotations.mkdir(exist_ok=True)
    out_videos.mkdir(exist_ok=True)

    for trial_dir in sequences_dir.iterdir():
        if not trial_dir.is_dir():
            continue

        trial_name = trial_dir.name

        # --- 1) Handle annotations JSON ---
        src_annotations_dir = trial_dir / "annotations"
        src_json = src_annotations_dir / "instances_default.json"
        dst_json = out_annotations / f"{trial_name}.json"

        if src_json.is_file():
            shutil.copy2(src_json, dst_json)
            shutil.rmtree(src_annotations_dir)
            print(f"Copied JSON: {src_json} -> {dst_json}")
            print(f"Deleted folder: {src_annotations_dir}")
        else:
            print(f"Skipped JSON for {trial_name}: {src_json} not found")

        # --- 2) Handle video ---
        src_video = trial_dir / "visualization.mp4"
        dst_video = out_videos / f"{trial_name}.mp4"

        if src_video.is_file():
            shutil.copy2(src_video, dst_video)
            src_video.unlink()
            print(f"Copied video: {src_video} -> {dst_video}")
            print(f"Deleted file: {src_video}")
        else:
            print(f"Skipped video for {trial_name}: {src_video} not found")

        # --- 3) Move images up one level ---
        images_dir = trial_dir / "images"

        if images_dir.is_dir():
            for item in images_dir.iterdir():
                target = trial_dir / item.name

                # If a file with same name exists, you can choose behavior:
                if target.exists():
                    raise FileExistsError(
                        f"Conflict: {target} already exists while moving {item}"
                    )

                shutil.move(str(item), str(target))
                print(f"Moved: {item} -> {target}")

            # Remove the now-empty images folder
            images_dir.rmdir()
            print(f"Deleted empty folder: {images_dir}")
        else:
            print(f"No images folder for {trial_name}")


if __name__ == "__main__":
    flatten_sequences(".")
