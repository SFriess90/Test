import os

def load_annotations_to_coco(anno_file_path):
    coco_annotations = []
    annotation_id = 1  # unique ID for each annotation

    with open(anno_file_path, 'r') as f:
        for line in f:
            line = line.strip()
            if not line:
                continue

            parts = line.split(',')
            if len(parts) != 6:
                raise ValueError(f"Invalid line format: {line}")

            frame_id = int(parts[0])
            x = float(parts[1])
            y = float(parts[2])
            w = float(parts[3])
            h = float(parts[4])
            brightness = float(parts[5])

            annotation = {
                "id": annotation_id,
                "image_id": frame_id,  # assuming frame_id maps to image_id
                "category_id": 1,      # adjust if you have multiple classes
                "bbox": [x, y, w, h],
                "area": w * h,
                "iscrowd": 0,
                # optional custom field
                "brightness": brightness
            }

            coco_annotations.append(annotation)
            annotation_id += 1

    return coco_annotations


if __name__ == "__main__":
    anno_path = os.path.join("dataset", "gt", "anno.txt")
    annotations = load_annotations_to_coco(anno_path)

    # Example: print first few annotations
    for ann in annotations[:5]:
        print(ann)

def load_images_to_coco_simple(sequence_path):
    import os

    image_files = sorted([
        f for f in os.listdir(sequence_path)
        if f.lower().endswith((".png", ".jpg", ".jpeg"))
    ])

    images = []
    for idx, filename in enumerate(image_files, start=1):
        images.append({
            "id": idx,
            "file_name": filename
        })

    return images
